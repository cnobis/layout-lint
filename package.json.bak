{
  "name": "layout-lint",
  "version": "1.0.8",
  "description": "A declarative DSL for testing CSS layout constraints in the browser",
  "repository": "https://github.com/cnobis/layout-lint",
  "license": "MIT",
  "author": {
    "name": "Christopher Nobis",
    "email": "christophernobis.dev@icloud.com"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js"
    },
    "./layout_lint.wasm": "./layout_lint.wasm"
  },
  "keywords": [
    "layout",
    "css",
    "testing",
    "dom",
    "tree-sitter",
    "dsl",
    "constraints"
  ],
  "files": [
    "dist/**",
    "layout_lint.wasm"
  ],
  "dependencies": {
    "web-tree-sitter": "^0.25.8"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.8",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "echo 'Nothing to build - using prebuilt WASM'",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test test/*.test.js",
    "build:wasm": "tree-sitter build --wasm -o layout_lint.wasm",
    "build:ts": "tsc",
    "serve": "npx http-server -c-1 . || npx serve -n ."
  },
  "type": "module"
}
