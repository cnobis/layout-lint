{
  "name": "tree-sitter-layout-lint",
  "version": "0.1.0",
  "description": "LayoutLint grammar + JS library for testing CSS layouts",
  "repository": "https://github.com/cnobis/layout-lint",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Christopher Nobis",
    "email": "christophernobis.dev@icloud.com"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "layout_lint"
  ],
  "files": [
    "dist/**",
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "*.wasm",
    "demo/**"
  ],
  "dependencies": {
    "node-addon-api": "^8.3.1",
    "node-gyp-build": "^4.8.4",
    "web-tree-sitter": "^0.25.8"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.8",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js",
    "build:wasm": "tree-sitter build --wasm -o layout_lint.wasm",
    "build:ts": "tsc",
    "serve": "npx http-server -c-1 . || npx serve -n ."
  }
}
