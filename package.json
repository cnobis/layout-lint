{
  "name": "layout-lint",
  "version": "1.1.0",
  "description": "A declarative DSL for testing CSS layout constraints in the browser",
  "repository": "https://github.com/cnobis/layout-lint",
  "license": "MIT",
  "author": {
    "name": "Christopher Nobis",
    "email": "christophernobis.dev@icloud.com"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js"
    },
    "./diagnostics": {
      "types": "./dist/core/diagnostic-format.d.ts",
      "import": "./dist/core/diagnostic-format.js"
    },
    "./diagnostic-codes": {
      "types": "./dist/core/diagnostic-codes.d.ts",
      "import": "./dist/core/diagnostic-codes.js"
    },
    "./wasm/layout-lint": "./layout_lint.wasm",
    "./layout_lint.wasm": "./layout_lint.wasm",
    "./package.json": "./package.json",
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.bundle.js"
    },
    "./web-component": {
      "types": "./dist/web-component.d.ts",
      "import": "./dist/web-component.bundle.js"
    }
  },
  "keywords": [
    "layout",
    "css",
    "testing",
    "dom",
    "tree-sitter",
    "dsl",
    "constraints"
  ],
  "files": [
    "dist/**",
    "layout_lint.wasm",
    "README.md",
    "THIRD_PARTY_LICENSES.md"
  ],
  "dependencies": {
    "web-tree-sitter": "^0.25.8"
  },
  "devDependencies": {
    "ebnf2railroad": "^1.14.2",
    "esbuild": "^0.28.0",
    "http-server": "^14.1.1",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.8",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "tree-sitter": "^0.22.4"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "install": "echo 'Nothing to build - using prebuilt WASM'",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test test/*.test.js",
    "build:wasm": "tree-sitter build --wasm -o layout_lint.wasm",
    "build:railroad": "node scripts/gen-railroad.mjs",
    "build:ts": "tsc && node scripts/build-wasm-inline.mjs && node scripts/build-bundles.mjs",
    "build:site": "npm run build:ts && npm run build:railroad && node scripts/build-site.mjs",
    "serve": "npx http-server -c-1 -o /demo/index.html",
    "demo": "npm run serve"
  },
  "type": "module"
}
